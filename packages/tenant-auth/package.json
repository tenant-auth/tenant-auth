{
  "name": "tenant-auth",
  "version": "0.0.1",
  "description": "The most comprehensive multi-tenancy auth framework for TypeScript.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tenant-auth/tenant-auth.git",
    "directory": "packages/multi-tenancy"
  },
  "keywords": [
    "multi-tenancy",
    "tenant-auth",
    "auth",
    "core",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "dependencies": {
    "@tenant-auth/core": "workspace:*",
    "better-call": "catalog:",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}