{
  "name": "@tenant-auth/root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/multi-tenancy/multi-tenancy.git"
  },
  "scripts": {
    "build": "turbo build --filter=./packages/*",
    "dev": "turbo dev --filter=./packages/*",
    "changeset": "changeset",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci:release": "turbo clean --filter=./packages/* && turbo build --filter=./packages/* && changeset publish",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.3.2",
    "turbo": "^2.9.3",
    "typescript": "catalog:"
  }
}